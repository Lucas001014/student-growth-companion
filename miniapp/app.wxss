page { 
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif; 
  background: #060b14; 
  color: #e2e8f0; 
  font-size: 28rpx; 
  min-height: 100vh;
}

.container { padding: 24rpx; box-sizing: border-box; }

.card { 
  background: rgba(15, 23, 42, 0.8); 
  border-radius: 20rpx; 
  padding: 28rpx; 
  margin-bottom: 24rpx; 
  border: 1px solid rgba(255,255,255,0.06);
}

.btn-primary { background: linear-gradient(135deg, #60a5fa, #3b82f6) !important; color: #fff !important; border-radius: 16rpx; }
.btn-success { background: linear-gradient(135deg, #10b981, #059669) !important; color: #fff !important; border-radius: 16rpx; }
.btn-warning { background: linear-gradient(135deg, #f59e0b, #d97706) !important; color: #fff !important; border-radius: 16rpx; }
.btn-danger { background: linear-gradient(135deg, #ef4444, #dc2626) !important; color: #fff !important; border-radius: 16rpx; }

.tag-n { color: #8e8e93; background: rgba(142,142,147,0.15); padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; border: 1px solid rgba(142,142,147,0.2); }
.tag-r { color: #0a84ff; background: rgba(10,132,255,0.15); padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; border: 1px solid rgba(10,132,255,0.3); }
.tag-sr { color: #ff9f0a; background: rgba(255,159,10,0.15); padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; border: 1px solid rgba(255,159,10,0.3); }
.tag-ssr { color: #ff2d55; background: rgba(255,45,85,0.15); padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; border: 1px solid rgba(255,45,85,0.3); }

.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.text-muted { color: #4a5568; font-size: 24rpx; }
.section-title { font-size: 32rpx; font-weight: 600; margin-bottom: 20rpx; color: #94a3b8; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: rgba(255,255,255,0.06); border: 2px solid rgba(255,255,255,0.08); }
.avatar-lg { width: 160rpx; height: 160rpx; border-radius: 50%; }
.divider { height: 1rpx; background: rgba(255,255,255,0.06); margin: 20rpx 0; }

.glow-ssr { box-shadow: 0 0 20rpx rgba(255,45,85,0.4); }
.glow-sr { box-shadow: 0 0 20rpx rgba(255,159,10,0.4); }
.glow-r { box-shadow: 0 0 20rpx rgba(10,132,255,0.4); }
.glow-n { box-shadow: 0 0 20rpx rgba(142,142,147,0.2); }

.safe-area-top { padding-top: constant(safe-area-inset-top); padding-top: env(safe-area-inset-top); }
.safe-area-bottom { padding-bottom: constant(safe-area-inset-bottom); padding-bottom: env(safe-area-inset-bottom); }
