page { 
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif; 
  background: #f1f5f9; 
  color: #0f172a; 
  font-size: 28rpx; 
  min-height: 100vh;
}

.container { padding: 24rpx; box-sizing: border-box; }

.card { 
  background: #ffffff; 
  border-radius: 20rpx; 
  padding: 28rpx; 
  margin-bottom: 24rpx; 
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.btn-primary { background: linear-gradient(135deg, #3b82f6, #2563eb) !important; color: #fff !important; border-radius: 16rpx; }
.btn-success { background: linear-gradient(135deg, #22c55e, #16a34a) !important; color: #fff !important; border-radius: 16rpx; }
.btn-warning { background: linear-gradient(135deg, #fbbf24, #f59e0b) !important; color: #fff !important; border-radius: 16rpx; }
.btn-orange { background: linear-gradient(135deg, #fb923c, #f97316) !important; color: #fff !important; border-radius: 16rpx; }
.btn-danger { background: linear-gradient(135deg, #ef4444, #dc2626) !important; color: #fff !important; border-radius: 16rpx; }
.btn-purple { background: linear-gradient(135deg, #a855f7, #7c3aed) !important; color: #fff !important; border-radius: 16rpx; }

.tag-n { color: #64748b; background: #f1f5f9; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; }
.tag-r { color: #2563eb; background: #dbeafe; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; }
.tag-sr { color: #f97316; background: #fed7aa; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; }
.tag-ssr { color: #dc2626; background: #fee2e2; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; }
.tag-green { color: #16a34a; background: #dcfce7; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; }
.tag-purple { color: #7c3aed; background: #ede9fe; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 22rpx; }

.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.text-muted { color: #64748b; font-size: 24rpx; }
.text-small { font-size: 24rpx; }
.text-primary { color: #2563eb; }
.text-orange { color: #f97316; }
.text-green { color: #16a34a; }
.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 20rpx; color: #0f172a; }
.section-sub { font-size: 24rpx; color: #64748b; margin-bottom: 24rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.avatar-lg { width: 160rpx; height: 160rpx; border-radius: 50%; font-size: 80rpx; }
.divider { height: 1rpx; background: #e2e8f0; margin: 20rpx 0; }

.badge-ssr { box-shadow: 0 4rpx 16rpx rgba(220, 38, 38, 0.25); }
.badge-sr { box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25); }
.badge-r { box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.25); }

.safe-area-top { padding-top: constant(safe-area-inset-top); padding-top: env(safe-area-inset-top); }
.safe-area-bottom { padding-bottom: constant(safe-area-inset-bottom); padding-bottom: env(safe-area-inset-bottom); }

.card-blue { background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%); }
.card-orange { background: linear-gradient(135deg, #ffedd5 0%, #fef3c7 100%); }
.card-green { background: linear-gradient(135deg, #dcfce7 0%, #d1fae5 100%); }
.card-purple { background: linear-gradient(135deg, #ede9fe 0%, #f5f3ff 100%); }

.input-light {
  width: 100%;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
}
.input-light::placeholder { color: #94a3b8; }
