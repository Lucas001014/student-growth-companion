.filter-bar { display: flex; background: #fff; border-radius: 16rpx; padding: 16rpx; margin-bottom: 30rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.filter-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #6b7280; border-radius: 12rpx; }
.filter-item.active { background: #409EFF; color: #fff; font-weight: 600; }
.skin-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.skin-card { background: #fff; border-radius: 16rpx; padding: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.skin-card.not-owned { opacity: 0.5; }
.skin-image { position: relative; width: 100%; height: 280rpx; border-radius: 12rpx; overflow: hidden; background: #f3f4f6; }
.skin-image image { width: 100%; height: 100%; display: block; }
.skin-tag { position: absolute; top: 12rpx; right: 12rpx; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: bold; }
.skin-name { text-align: center; padding: 16rpx 0 4rpx; font-size: 28rpx; font-weight: 500; }
