.container { 
  padding: 24rpx 24rpx 80rpx 24rpx; 
  background: #f1f5f9; 
  min-height: 100vh;
}

/* 前三名展示 */
.top-three { 
  display: flex; 
  justify-content: space-around; 
  background: #ffffff; 
  border-radius: 24rpx; 
  padding: 40rpx 20rpx; 
  margin-bottom: 24rpx; 
  box-shadow: 0 4rpx 16rpx rgba(15,23,42,0.06);
  align-items: flex-end;
}

.top-item { 
  text-align: center; 
  flex: 1; 
  display: flex;
  flex-direction: column;
  align-items: center;
}

.top-item:nth-child(2) {
  order: -1;
}

.top-item:first-child {
  transform: scale(1.08);
}

.top-rank { 
  font-size: 44rpx; 
  font-weight: 700;
}

.top-item .avatar { 
  width: 100rpx; 
  height: 100rpx; 
  border-radius: 50%; 
  margin: 12rpx 0; 
  background: linear-gradient(135deg, #fbbf24, #f97316);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.2);
}

.top-item:nth-child(2) .avatar {
  background: linear-gradient(135deg, #cbd5e1, #94a3b8);
  box-shadow: 0 4rpx 16rpx rgba(100,116,139,0.2);
}

.top-item:last-child .avatar {
  background: linear-gradient(135deg, #fb923c, #c2410c);
  box-shadow: 0 4rpx 16rpx rgba(194,65,12,0.2);
}

.top-name { 
  font-size: 26rpx; 
  font-weight: 600; 
  color: #1e293b;
}

.top-points { 
  font-size: 24rpx; 
  color: #2563eb; 
  margin-top: 4rpx; 
  font-weight: 600;
}

/* 排行榜列表 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 12rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,0.04);
}

.rank-row { 
  display: flex; 
  align-items: center; 
  padding: 22rpx 0; 
  border-bottom: 2rpx solid #f1f5f9; 
  font-size: 28rpx; 
}

.rank-row:last-child { 
  border-bottom: none; 
}

.rank-header { 
  font-size: 24rpx; 
  color: #64748b; 
  font-weight: 500; 
  border-bottom: 2rpx solid #e2e8f0;
}

.me-row { 
  background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%); 
  border-radius: 12rpx; 
  padding: 22rpx 20rpx !important;
  margin: 0 -16rpx;
}

.me-tag { 
  display: inline-block; 
  font-size: 20rpx; 
  background: linear-gradient(135deg, #3b82f6, #2563eb); 
  color: #ffffff; 
  padding: 4rpx 16rpx; 
  border-radius: 20rpx; 
  margin-top: 4rpx; 
  font-weight: 600;
}

/* 排行位置的头像 */
.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #cbd5e1, #94a3b8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-name {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.rank-score {
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx; 
  font-weight: 700; 
  color: #0f172a; 
  margin: 28rpx 0 18rpx 4rpx;
}
