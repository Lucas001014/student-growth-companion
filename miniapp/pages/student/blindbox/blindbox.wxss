.container { 
  padding: 24rpx 24rpx 80rpx 24rpx; 
  background: #f1f5f9; 
  min-height: 100vh;
}

/* 盲盒主卡片 */
.box-card { 
  background: linear-gradient(135deg, #fbbf24 0%, #f97316 50%, #ea580c 100%); 
  border-radius: 28rpx; 
  padding: 56rpx 40rpx; 
  text-align: center; 
  color: #ffffff; 
  margin-bottom: 24rpx; 
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.25);
  position: relative;
  overflow: hidden;
}

.box-card::before {
  content: '✨';
  position: absolute;
  font-size: 80rpx;
  opacity: 0.15;
  top: 20rpx;
  right: 30rpx;
}

.box-emoji { 
  font-size: 120rpx; 
  margin-bottom: 12rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.2));
}

.box-title { 
  font-size: 36rpx; 
  font-weight: 700; 
  margin-top: 16rpx; 
}

.box-desc { 
  font-size: 24rpx; 
  margin-top: 8rpx; 
  opacity: 0.95; 
}

.box-pool { 
  margin-top: 28rpx; 
  background: rgba(255,255,255,0.22); 
  padding: 20rpx; 
  border-radius: 16rpx; 
}

.pool-tags { 
  display: flex; 
  flex-wrap: wrap; 
  justify-content: center; 
  margin-top: 12rpx; 
}

.pool-tag { 
  margin: 6rpx; 
  font-size: 22rpx; 
  padding: 8rpx 16rpx; 
  border-radius: 20rpx; 
  color: #ffffff; 
  background: rgba(255,255,255,0.35); 
  font-weight: 500;
}

.draw-btn { 
  margin-top: 30rpx !important; 
  border-radius: 50rpx !important; 
  background: linear-gradient(135deg, #ffffff, #fef3c7) !important;
  color: #ea580c !important;
  font-weight: 700 !important;
  font-size: 30rpx !important;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.15);
}

/* 结果卡片 */
.result-card { 
  background: linear-gradient(135deg, #60a5fa 0%, #2563eb 50%, #7c3aed 100%); 
  border-radius: 28rpx; 
  padding: 56rpx 40rpx; 
  text-align: center; 
  color: #ffffff; 
  margin-bottom: 24rpx; 
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.25);
}

.result-emoji { 
  font-size: 100rpx; 
}

.result-name { 
  font-size: 36rpx; 
  font-weight: 700; 
  margin: 20rpx 0 12rpx; 
}

.result-tag { 
  display: inline-block; 
  padding: 10rpx 24rpx; 
  border-radius: 24rpx; 
  font-size: 24rpx; 
  background: rgba(255,255,255,0.3);
  font-weight: 600;
}

.section-title { 
  font-size: 30rpx; 
  font-weight: 700; 
  color: #0f172a; 
  margin: 28rpx 0 18rpx 4rpx; 
}

/* 历史记录卡片 */
.card { 
  background: #ffffff; 
  border-radius: 20rpx; 
  padding: 12rpx 28rpx; 
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,0.04);
  margin-bottom: 20rpx;
}

.history-row { 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  padding: 20rpx 0; 
  border-bottom: 2rpx solid #f1f5f9; 
}

.history-row:last-child { 
  border-bottom: none; 
}

.item-title { 
  font-size: 28rpx; 
  font-weight: 500;
  color: #1e293b;
}

/* 辅助文字 */
.text-muted { 
  font-size: 22rpx; 
  color: #64748b; 
  margin-top: 6rpx; 
  display: block;
}

/* 空状态 */
.empty { 
  text-align: center; 
  padding: 48rpx 0; 
  color: #94a3b8; 
  font-size: 26rpx; 
}

/* 通用按钮覆盖 */
.btn-primary { 
  background: linear-gradient(135deg, #3b82f6, #2563eb) !important; 
  color: #fff !important; 
  border-radius: 16rpx; 
}

/* 稀有度标签 */
.tag-n { color: #64748b; background: #f1f5f9; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 500;}
.tag-r { color: #2563eb; background: #dbeafe; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 500;}
.tag-sr { color: #ea580c; background: #ffedd5; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 500;}
.tag-ssr { color: #dc2626; background: #fee2e2; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 600;}
