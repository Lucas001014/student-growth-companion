.box-card { background: linear-gradient(135deg, #fa709a, #fee140); border-radius: 24rpx; padding: 60rpx 40rpx; text-align: center; color: #fff; margin-bottom: 30rpx; }
.box-emoji { font-size: 120rpx; }
.box-title { font-size: 40rpx; font-weight: bold; margin-top: 20rpx; }
.box-desc { font-size: 26rpx; margin-top: 8rpx; opacity: 0.9; }
.box-pool { margin-top: 30rpx; background: rgba(255,255,255,0.2); padding: 20rpx; border-radius: 12rpx; }
.pool-tags { display: flex; flex-wrap: wrap; justify-content: center; margin-top: 12rpx; }
.pool-tag { margin: 6rpx; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 20rpx; color: #fff; background: rgba(0,0,0,0.3); }
.draw-btn { margin-top: 30rpx !important; border-radius: 50rpx !important; }
.result-card { background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 24rpx; padding: 60rpx 40rpx; text-align: center; color: #fff; margin-bottom: 30rpx; }
.result-emoji { font-size: 100rpx; }
.result-name { font-size: 36rpx; font-weight: bold; margin: 20rpx 0 12rpx; }
.result-tag { display: inline-block; padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.history-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 2rpx solid #f3f4f6; }
.history-row:last-child { border-bottom: none; }
.empty { text-align: center; padding: 40rpx 0; color: #909399; font-size: 26rpx; }
