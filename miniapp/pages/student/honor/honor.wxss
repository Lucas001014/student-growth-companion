.stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; margin-bottom: 30rpx; }
.stat-card { border-radius: 16rpx; padding: 30rpx 20rpx; text-align: center; color: #fff; }
.stat-blue { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.stat-green { background: linear-gradient(135deg, #43e97b, #38f9d7); }
.stat-orange { background: linear-gradient(135deg, #fa709a, #fee140); }
.stat-red { background: linear-gradient(135deg, #f093fb, #f5576c); }
.stat-num { font-size: 48rpx; font-weight: bold; }
.stat-label { font-size: 24rpx; margin-top: 8rpx; opacity: 0.9; }
.item-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 2rpx solid #f3f4f6; }
.item-row:last-child { border-bottom: none; }
.item-icon { font-size: 48rpx; margin-right: 20rpx; }
.item-info { flex: 1; }
.item-title { font-size: 30rpx; font-weight: 500; }
.log-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 2rpx solid #f3f4f6; }
.log-row:last-child { border-bottom: none; }
.log-pts { font-size: 32rpx; font-weight: bold; }
.log-pts.pos { color: #67C23A; }
.log-pts.neg { color: #F56C6C; }
.badge-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.badge-card { background: #fff; border-radius: 16rpx; padding: 30rpx 20rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.badge-card.locked { opacity: 0.4; }
.badge-emoji { font-size: 60rpx; margin-bottom: 12rpx; }
.badge-name { font-size: 28rpx; font-weight: 500; }
.badge-desc { font-size: 22rpx; color: #909399; margin-top: 4rpx; }
.empty { text-align: center; padding: 40rpx 0; color: #909399; font-size: 26rpx; }
