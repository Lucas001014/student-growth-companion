.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #374151; margin-bottom: 12rpx; font-weight: 500; }
.form-input { background: #f9fafb; border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; }
.upload-area { width: 100%; height: 320rpx; background: #f9fafb; border: 2rpx dashed #d1d5db; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; }
.upload-icon { font-size: 80rpx; color: #9ca3af; font-weight: 300; }
.upload-img { width: 100%; height: 100%; }
.radio-group { display: flex; gap: 20rpx; }
.radio-item { flex: 1; text-align: center; padding: 20rpx; border-radius: 12rpx; background: #f9fafb; border: 2rpx solid #e5e7eb; font-size: 28rpx; }
.radio-item.active { background: #409EFF; color: #fff; border-color: #409EFF; }
.submit-btn { border-radius: 12rpx !important; margin-top: 20rpx !important; }
