.container { 
  padding: 24rpx 24rpx 80rpx 24rpx; 
  background: #f1f5f9; 
  min-height: 100vh;
}

/* 个人资料卡片 */
.profile-card { 
  background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%); 
  border-radius: 28rpx; 
  padding: 36rpx; 
  margin-bottom: 28rpx; 
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.08);
  position: relative;
  overflow: hidden;
}

.profile-card::before {
  content: '✨';
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 40rpx;
  opacity: 0.5;
}

.avatar-lg { 
  width: 120rpx; 
  height: 120rpx; 
  border-radius: 32rpx; 
  background: linear-gradient(135deg, #3b82f6, #2563eb); 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.25);
}

.badge { 
  display: inline-block; 
  background: #ffffff; 
  padding: 8rpx 18rpx; 
  border-radius: 20rpx; 
  font-size: 22rpx; 
  color: #2563eb;
  font-weight: 500;
}

.points-bar { 
  margin-top: 28rpx; 
  padding: 28rpx 24rpx; 
  background: rgba(255,255,255,0.7);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.points-num { 
  font-size: 52rpx; 
  font-weight: 700; 
  color: #f97316;
  line-height: 1.1;
}

.points-label { 
  font-size: 24rpx; 
  color: #64748b; 
}

.section-title { 
  font-size: 30rpx; 
  font-weight: 700; 
  color: #0f172a; 
  margin: 28rpx 0 18rpx 4rpx; 
}

/* 皮肤墙横向滚动 */
.skins-scroll { 
  white-space: nowrap; 
  margin-bottom: 10rpx; 
}

.skin-item { 
  display: inline-block; 
  width: 200rpx; 
  margin-right: 20rpx; 
  background: #ffffff; 
  border-radius: 20rpx; 
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(15,23,42,0.06);
}

.skin-item image { 
  width: 200rpx; 
  height: 200rpx; 
  display: block; 
  background: #f1f5f9; 
}

.skin-name { 
  padding: 16rpx; 
  text-align: center; 
  font-size: 24rpx; 
  color: #475569; 
  font-weight: 500;
}

/* 荣誉动态卡片 */
.card { 
  background: #ffffff; 
  border-radius: 20rpx; 
  padding: 24rpx 28rpx; 
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,0.04);
}

.event { 
  display: flex; 
  align-items: center;
  padding: 20rpx 0; 
  border-bottom: 1px solid #f1f5f9; 
}

.event:last-child { 
  border-bottom: none; 
}

.event-dot { 
  font-size: 36rpx; 
  margin-right: 16rpx; 
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #ffedd5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.event-content { 
  flex: 1; 
  font-size: 26rpx; 
  color: #334155; 
}

.event-content text[style*="opacity"] {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
  display: block;
}

.text-muted { 
  font-size: 22rpx; 
  color: #64748b; 
  margin-top: 6rpx; 
  display: block;
}

/* 快捷入口 */
.quick-grid { 
  display: flex; 
  flex-wrap: wrap; 
  gap: 16rpx;
}

.quick-item { 
  width: calc(25% - 12rpx); 
  background: #ffffff; 
  border-radius: 20rpx; 
  padding: 24rpx 10rpx; 
  text-align: center; 
  box-sizing: border-box; 
  font-size: 24rpx; 
  color: #475569; 
  box-shadow: 0 2rpx 8rpx rgba(15,23,42,0.04);
  transition: all 0.2s;
}

.quick-icon { 
  font-size: 48rpx; 
  margin-bottom: 8rpx; 
}

/* 退出登录 */
.logout-btn { 
  display: inline-block; 
  padding: 18rpx 60rpx; 
  background: #ffffff; 
  border: 2rpx solid #fee2e2;
  border-radius: 40rpx; 
  color: #dc2626; 
  font-size: 26rpx; 
  font-weight: 500;
}
