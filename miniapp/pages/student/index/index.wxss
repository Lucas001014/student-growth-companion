.container { 
  padding: 24rpx 24rpx 80rpx 24rpx; 
  background: #060b14; 
  min-height: 100vh;
}

.profile-card { 
  background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(10,132,255,0.1)); 
  border: 1px solid rgba(16,185,129,0.2);
  border-radius: 24rpx; 
  padding: 40rpx; 
  margin-bottom: 30rpx; 
}

.avatar-wrap {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-lg { 
  width: 120rpx; 
  height: 120rpx; 
  border-radius: 60rpx; 
  background: rgba(255,255,255,0.08); 
  border: 2px solid rgba(16,185,129,0.3);
  display: flex; 
  align-items: center; 
  justify-content: center; 
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #e2e8f0;
  margin-bottom: 8rpx;
}

.user-class {
  font-size: 24rpx;
  color: #64748b;
}

.badge { 
  display: inline-block; 
  background: rgba(16,185,129,0.15); 
  padding: 6rpx 16rpx; 
  border-radius: 20rpx; 
  font-size: 22rpx; 
  color: #10b981;
  margin-right: 12rpx;
  border: 1px solid rgba(16,185,129,0.2);
}

.points-bar { 
  margin-top: 30rpx; 
  padding-top: 30rpx; 
  border-top: 1px solid rgba(255,255,255,0.06); 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-num { 
  font-size: 56rpx; 
  font-weight: 700; 
  color: #f59e0b;
}

.points-label { 
  font-size: 24rpx; 
  color: #4a5568; 
}

.section-title { 
  font-size: 28rpx; 
  font-weight: 600; 
  color: #94a3b8; 
  margin: 28rpx 0 20rpx 0; 
}

.skins-scroll { 
  white-space: nowrap; 
  margin-bottom: 10rpx; 
}

.skin-item { 
  display: inline-block; 
  width: 200rpx; 
  margin-right: 20rpx; 
  background: rgba(15,23,42,0.8); 
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16rpx; 
  overflow: hidden; 
}

.skin-item image { 
  width: 200rpx; 
  height: 200rpx; 
  display: block; 
  background: rgba(255,255,255,0.04); 
}

.skin-name { 
  padding: 16rpx; 
  text-align: center; 
  font-size: 24rpx; 
  color: #94a3b8; 
}

.card { 
  background: rgba(15,23,42,0.6); 
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16rpx; 
  padding: 20rpx 24rpx; 
}

.event { 
  display: flex; 
  padding: 16rpx 0; 
  border-bottom: 1px solid rgba(255,255,255,0.04); 
}

.event:last-child { 
  border-bottom: none; 
}

.event-dot { 
  font-size: 36rpx; 
  margin-right: 16rpx; 
}

.event-content { 
  flex: 1; 
  font-size: 26rpx; 
  color: #c8d6e5; 
}

.text-muted { 
  font-size: 22rpx; 
  color: #4a5568; 
  margin-top: 6rpx; 
}

.quick-grid { 
  display: flex; 
  flex-wrap: wrap; 
  gap: 16rpx;
}

.quick-item { 
  width: calc(25% - 12rpx); 
  background: rgba(15,23,42,0.8); 
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16rpx; 
  padding: 24rpx 10rpx; 
  text-align: center; 
  box-sizing: border-box; 
  font-size: 24rpx; 
  color: #94a3b8; 
}

.quick-icon { 
  font-size: 48rpx; 
  margin-bottom: 8rpx; 
}

.logout-btn { 
  display: inline-block; 
  padding: 16rpx 60rpx; 
  background: rgba(239,68,68,0.1); 
  border: 1px solid rgba(239,68,68,0.2);
  border-radius: 40rpx; 
  color: #ef4444; 
  font-size: 26rpx; 
}
