.filter-bar { display: flex; background: #fff; border-radius: 16rpx; padding: 16rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.filter-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #6b7280; border-radius: 12rpx; }
.filter-item.active { background: #409EFF; color: #fff; font-weight: 600; }
.hw-card { padding: 24rpx; }
.hw-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.hw-title { font-size: 30rpx; font-weight: 600; }
.hw-meta { display: flex; justify-content: space-between; font-size: 24rpx; margin-bottom: 16rpx; }
.hw-image { width: 100%; height: 360rpx; border-radius: 12rpx; background: #f3f4f6; }
.hw-desc { margin-top: 16rpx; font-size: 26rpx; color: #4b5563; line-height: 1.5; }
.hw-tags { display: flex; flex-wrap: wrap; margin-top: 12rpx; }
.hw-tag { background: #eff6ff; color: #3b82f6; padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; margin-right: 8rpx; margin-top: 8rpx; }
.empty { text-align: center; padding: 80rpx 0; color: #909399; font-size: 26rpx; }
