.container { 
  padding: 24rpx 24rpx 80rpx 24rpx; 
  background: #fff7ed; 
  min-height: 100vh;
}

/* Tabs */
.tabs { 
  display: flex; 
  background: #ffffff; 
  border-radius: 20rpx; 
  padding: 10rpx; 
  margin-bottom: 20rpx; 
  box-shadow: 0 2rpx 12rpx rgba(120,53,15,0.05); 
}

.tab { 
  flex: 1; 
  text-align: center; 
  padding: 20rpx 0; 
  font-size: 26rpx; 
  color: #64748b; 
  border-radius: 14rpx; 
  font-weight: 500;
}

.tab.active { 
  background: linear-gradient(135deg, #fb923c, #f97316); 
  color: #ffffff; 
  font-weight: 600; 
  box-shadow: 0 4rpx 12rpx rgba(249,115,22,0.25);
}

/* 表单 */
.form-item { 
  margin-bottom: 24rpx; 
}

.form-label { 
  font-size: 26rpx; 
  color: #1c1917; 
  margin-bottom: 12rpx; 
  font-weight: 600; 
}

.form-input { 
  background: #fff7ed; 
  border: 2rpx solid #fed7aa; 
  border-radius: 14rpx; 
  padding: 20rpx 24rpx; 
  font-size: 28rpx; 
  color: #1c1917;
}

.picker { 
  background: #fff7ed; 
  border: 2rpx solid #fed7aa; 
  border-radius: 14rpx; 
  padding: 20rpx 24rpx; 
  font-size: 28rpx; 
  color: #1c1917;
}

.section-title-sm { 
  font-size: 28rpx; 
  font-weight: 600; 
  margin: 16rpx 0 16rpx; 
  color: #1c1917; 
}

/* 皮肤网格 */
.skin-grid { 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 16rpx; 
}

.skin-item { 
  background: #fff7ed; 
  border-radius: 16rpx; 
  overflow: hidden; 
  border: 4rpx solid transparent; 
  transition: all 0.2s ease;
}

.skin-item.selected { 
  border-color: #f97316; 
  background: linear-gradient(135deg, #ffedd5, #fef3c7);
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.15);
}

.skin-item image { 
  width: 100%; 
  height: 200rpx; 
  display: block; 
  background: linear-gradient(135deg, #ffedd5, #fed7aa);
}

.skin-name { 
  text-align: center; 
  padding: 12rpx; 
  font-size: 24rpx; 
  color: #1c1917;
  font-weight: 500;
}

/* 称号列表 */
.title-list { 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 16rpx; 
}

.title-item { 
  display: flex; 
  align-items: center; 
  padding: 20rpx; 
  background: #fff7ed; 
  border-radius: 14rpx; 
  border: 4rpx solid transparent; 
  transition: all 0.2s ease;
}

.title-item.selected { 
  border-color: #f97316; 
  background: linear-gradient(135deg, #ffedd5, #fef3c7);
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.15);
}

.title-emoji { 
  font-size: 40rpx; 
  margin-right: 12rpx; 
}

.title-name { 
  font-size: 26rpx; 
  color: #1c1917;
  font-weight: 500;
}

.mt-btn { 
  border-radius: 14rpx !important; 
  margin-top: 20rpx !important; 
  background: linear-gradient(135deg, #fb923c, #f97316) !important;
  color: #ffffff !important;
  font-weight: 600 !important;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.25);
}
