.tabs { display: flex; background: #fff; border-radius: 16rpx; padding: 8rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #6b7280; border-radius: 12rpx; }
.tab.active { background: #409EFF; color: #fff; font-weight: 600; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #374151; margin-bottom: 12rpx; font-weight: 500; }
.form-input { background: #f9fafb; border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; }
.picker { background: #f9fafb; border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; }
.section-title-sm { font-size: 26rpx; font-weight: 500; margin: 16rpx 0 12rpx; color: #374151; }
.skin-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.skin-item { background: #f9fafb; border-radius: 12rpx; overflow: hidden; border: 4rpx solid transparent; }
.skin-item.selected { border-color: #409EFF; }
.skin-item image { width: 100%; height: 200rpx; display: block; }
.skin-name { text-align: center; padding: 12rpx; font-size: 24rpx; }
.title-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.title-item { display: flex; align-items: center; padding: 20rpx; background: #f9fafb; border-radius: 12rpx; border: 4rpx solid transparent; }
.title-item.selected { border-color: #409EFF; background: rgba(64,158,255,0.08); }
.title-emoji { font-size: 40rpx; margin-right: 12rpx; }
.title-name { font-size: 26rpx; }
.mt-btn { border-radius: 12rpx !important; margin-top: 20rpx !important; }
