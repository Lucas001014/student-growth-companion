<view class="container">
  <view class="tabs">
    <view class="tab {{tab === 'points' ? 'active' : ''}}" bindtap="switchTab" data-tab="points">积分发放</view>
    <view class="tab {{tab === 'skin' ? 'active' : ''}}" bindtap="switchTab" data-tab="skin">皮肤发放</view>
    <view class="tab {{tab === 'title' ? 'active' : ''}}" bindtap="switchTab" data-tab="title">称号发放</view>
  </view>

  <block wx:if="{{tab === 'points'}}">
    <view class="card">
      <view class="form-item">
        <view class="form-label">选择学生</view>
        <picker range="{{studentNames}}" bindchange="onStudentChange">
          <view class="picker">{{studentNames[studentIdx] || '请选择'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <view class="form-label">积分数量</view>
        <input class="form-input" type="digit" placeholder="请输入积分" value="{{points}}" bindinput="onInput" data-key="points" />
      </view>
      <view class="form-item">
        <view class="form-label">理由</view>
        <input class="form-input" placeholder="请输入发放理由" value="{{reason}}" bindinput="onInput" data-key="reason" />
      </view>
      <button class="btn-primary" bindtap="submit">发放积分</button>
    </view>
  </block>

  <block wx:elif="{{tab === 'skin'}}">
    <view class="card">
      <view class="form-item">
        <view class="form-label">选择学生</view>
        <picker range="{{studentNames}}" bindchange="onStudentChange">
          <view class="picker">{{studentNames[studentIdx] || '请选择'}}</view>
        </picker>
      </view>
      <view class="section-title-sm">选择皮肤</view>
      <view class="skin-grid">
        <view wx:for="{{skins}}" wx:key="id" class="skin-item {{selectedSkin === item.id ? 'selected' : ''}}" bindtap="selectSkin" data-id="{{item.id}}">
          <image src="{{item.imageUrl}}" mode="aspectFill" />
          <view class="skin-name">{{item.name}}</view>
        </view>
      </view>
      <button class="btn-primary mt-btn" bindtap="grantSkin">发放皮肤</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="form-item">
        <view class="form-label">选择学生</view>
        <picker range="{{studentNames}}" bindchange="onStudentChange">
          <view class="picker">{{studentNames[studentIdx] || '请选择'}}</view>
        </picker>
      </view>
      <view class="section-title-sm">选择称号</view>
      <view class="title-list">
        <view wx:for="{{titles}}" wx:key="id" class="title-item {{selectedTitle === item.id ? 'selected' : ''}}" bindtap="selectTitle" data-id="{{item.id}}">
          <view class="title-emoji">{{item.icon}}</view>
          <view class="title-name">{{item.name}}</view>
        </view>
      </view>
      <button class="btn-primary mt-btn" bindtap="grantTitle">发放称号</button>
    </view>
  </block>
</view>
