.tabs { display: flex; background: #fff; border-radius: 16rpx; padding: 8rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #6b7280; border-radius: 12rpx; }
.tab.active { background: #409EFF; color: #fff; font-weight: 600; }
.appr-card { padding: 24rpx; }
.appr-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.appr-title { font-size: 30rpx; font-weight: 600; }
.appr-desc { margin-top: 16rpx; font-size: 26rpx; color: #4b5563; background: #f9fafb; padding: 16rpx; border-radius: 8rpx; line-height: 1.5; }
.appr-action { display: flex; gap: 20rpx; margin-top: 20rpx; }
.appr-action button { flex: 1; border-radius: 12rpx !important; font-size: 28rpx; }
.status { font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.status-pending { background: #fef3c7; color: #92400e; }
.status-approved { background: #d1fae5; color: #065f46; }
.status-rejected { background: #fee2e2; color: #991b1b; }
.empty { text-align: center; padding: 60rpx 0; color: #909399; font-size: 26rpx; }
