.login-wrap { 
  padding: 80rpx 40rpx 40rpx; 
  min-height: 100vh; 
  background: linear-gradient(180deg, #eff6ff 0%, #fef3c7 50%, #dcfce7 100%);
  position: relative;
  box-sizing: border-box;
}

.decor-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
  pointer-events: none;
}
.decor-1 {
  width: 500rpx; height: 500rpx;
  background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, transparent 70%);
  top: -150rpx; left: -100rpx;
}
.decor-2 {
  width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, rgba(249,115,22,0.15) 0%, transparent 70%);
  bottom: -100rpx; right: -80rpx;
}

.decor-dots {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image: radial-gradient(circle, rgba(59,130,246,0.06) 2rpx, transparent 2rpx);
  background-size: 50rpx 50rpx;
  pointer-events: none;
}

.login-card { 
  background: #ffffff; 
  border-radius: 32rpx; 
  padding: 60rpx 40rpx; 
  position: relative;
  z-index: 1;
  box-shadow: 0 20rpx 60rpx rgba(15,23,42,0.08), 0 4rpx 12rpx rgba(15,23,42,0.04);
}

.logo-box {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo { 
  width: 140rpx; height: 140rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx; 
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.25);
}

.title { 
  font-size: 38rpx; 
  font-weight: 700; 
  text-align: center; 
  color: #0f172a;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.subtitle { 
  font-size: 22rpx; 
  text-align: center; 
  color: #64748b; 
  margin-bottom: 24rpx; 
  letter-spacing: 1rpx;
}

.welcome-tip {
  text-align: center;
  font-size: 24rpx;
  color: #475569;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #fef3c7 100%);
  border-radius: 16rpx;
  margin-bottom: 36rpx;
}

.tabs { 
  display: flex; 
  background: #f1f5f9; 
  border-radius: 18rpx; 
  padding: 8rpx; 
  margin-bottom: 40rpx;
}

.tab { 
  flex: 1; 
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0; 
  border-radius: 14rpx; 
  font-size: 26rpx; 
  color: #64748b;
  transition: all 0.25s;
}

.tab-icon { font-size: 28rpx; }

.tab.active { 
  background: #ffffff; 
  color: #2563eb; 
  font-weight: 600; 
  box-shadow: 0 2rpx 8rpx rgba(15,23,42,0.06);
}

.input { 
  width: 100%;
  background: #f8fafc; 
  border: 2rpx solid #e2e8f0; 
  border-radius: 16rpx; 
  padding: 28rpx 32rpx; 
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.input::placeholder {
  color: #94a3b8;
}

.submit { 
  width: 100%;
  border-radius: 16rpx; 
  padding: 28rpx; 
  font-size: 30rpx; 
  margin-top: 20rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 1rpx;
}
.submit::after { border: none; }

.submit-blue { 
  background: linear-gradient(135deg, #3b82f6, #2563eb) !important;
  color: #fff !important;
  box-shadow: 0 8rpx 20rpx rgba(37,99,235,0.25);
}
.submit-orange { 
  background: linear-gradient(135deg, #fb923c, #f97316) !important;
  color: #fff !important;
  box-shadow: 0 8rpx 20rpx rgba(249,115,22,0.25);
}
.submit-purple { 
  background: linear-gradient(135deg, #a855f7, #7c3aed) !important;
  color: #fff !important;
  box-shadow: 0 8rpx 20rpx rgba(124,58,237,0.25);
}

.footer-text {
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}
