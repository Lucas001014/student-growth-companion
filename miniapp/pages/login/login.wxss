.login-wrap { 
  padding: 80rpx 40rpx; 
  min-height: 100vh; 
  background: linear-gradient(180deg, #060b14 0%, #0f172a 50%, #1e1b4b 100%);
  position: relative;
  box-sizing: border-box;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
  pointer-events: none;
}
.orb-1 {
  width: 600rpx; 
  height: 600rpx;
  background: rgba(0, 245, 212, 0.15);
  top: -200rpx; 
  left: -100rpx;
}
.orb-2 {
  width: 500rpx; 
  height: 500rpx;
  background: rgba(123, 44, 247, 0.18);
  bottom: -150rpx; 
  right: -50rpx;
}

.login-card { 
  background: rgba(10, 14, 26, 0.85); 
  border-radius: 28rpx; 
  padding: 60rpx 40rpx; 
  border: 1px solid rgba(0, 245, 212, 0.12);
  position: relative;
  z-index: 1;
}

.logo { 
  font-size: 100rpx; 
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
}

.title { 
  font-size: 36rpx; 
  font-weight: 800; 
  text-align: center; 
  background: linear-gradient(135deg, #00f5d4, #7b2ff7);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.subtitle { 
  font-size: 22rpx; 
  text-align: center; 
  color: #64748b; 
  margin-bottom: 40rpx; 
}

.tabs { 
  display: flex; 
  background: rgba(255,255,255,0.04); 
  border-radius: 16rpx; 
  padding: 6rpx; 
  margin-bottom: 40rpx;
  border: 1px solid rgba(255,255,255,0.06);
}

.tab { 
  flex: 1; 
  text-align: center; 
  padding: 20rpx 0; 
  border-radius: 12rpx; 
  font-size: 26rpx; 
  color: #64748b;
  transition: all 0.25s;
}

.tab.active { 
  background: linear-gradient(135deg, rgba(0,245,212,0.15), rgba(123,44,247,0.1)); 
  color: #00f5d4; 
  font-weight: 600; 
}

.input { 
  width: 100%;
  background: rgba(0,0,0,0.3); 
  border: 1px solid rgba(255,255,255,0.06); 
  border-radius: 16rpx; 
  padding: 28rpx 32rpx; 
  font-size: 28rpx;
  color: #e2e8f0;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.input::placeholder {
  color: #4a5568;
}

.submit { 
  width: 100%;
  background: linear-gradient(135deg, #00f5d4, #7b2ff7) !important; 
  color: #fff !important; 
  border-radius: 16rpx; 
  padding: 28rpx; 
  font-size: 32rpx; 
  margin-top: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
}

.submit::after {
  border: none;
}
