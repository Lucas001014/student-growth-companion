<view class="login-wrap">
  <view class="login-card">
    <view class="logo">🏆</view>
    <view class="title">班级荣誉皮肤系统</view>
    <view class="subtitle">Class Honor Skin System</view>
    <view class="tabs">
      <view class="tab {{tab === 'student' ? 'active' : ''}}" bindtap="switchTab" data-tab="student">学生</view>
      <view class="tab {{tab === 'teacher' ? 'active' : ''}}" bindtap="switchTab" data-tab="teacher">教师</view>
      <view class="tab {{tab === 'admin' ? 'active' : ''}}" bindtap="switchTab" data-tab="admin">管理员</view>
    </view>
    <block wx:if="{{tab === 'student'}}">
      <input class="input" placeholder="学号" value="{{studentNo}}" bindinput="onInput" data-key="studentNo" />
      <input class="input" placeholder="班级验证码" value="{{classVerifyCode}}" bindinput="onInput" data-key="classVerifyCode" />
    </block>
    <block wx:else>
      <input class="input" placeholder="手机号" value="{{phone}}" bindinput="onInput" data-key="phone" />
      <input class="input" placeholder="密码" password value="{{password}}" bindinput="onInput" data-key="password" />
    </block>
    <button class="submit" bindtap="onSubmit">登 录</button>
  </view>
</view>
