<view class="container">
  <view class="tabs">
    <view class="tab {{tab === 'skins' ? 'active' : ''}}" bindtap="switchTab" data-tab="skins">皮肤</view>
    <view class="tab {{tab === 'titles' ? 'active' : ''}}" bindtap="switchTab" data-tab="titles">称号</view>
    <view class="tab {{tab === 'badges' ? 'active' : ''}}" bindtap="switchTab" data-tab="badges">身份徽章</view>
  </view>

  <block wx:if="{{tab === 'skins'}}">
    <view class="item-grid">
      <view wx:for="{{skins}}" wx:key="id" class="item-card" bindtap="edit" data-id="{{item.id}}">
        <image src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="item-name">{{item.name}}</view>
        <view class="tag-{{item.rarity}} item-tag">{{item.rarity}}</view>
      </view>
      <view class="item-card add-card" bindtap="addItem">
        <view class="add-icon">+</view>
        <view class="item-name">新增皮肤</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{tab === 'titles'}}">
    <view class="item-grid">
      <view wx:for="{{titles}}" wx:key="id" class="item-card" bindtap="edit" data-id="{{item.id}}">
        <view class="emoji">{{item.icon}}</view>
        <view class="item-name">{{item.name}}</view>
      </view>
      <view class="item-card add-card" bindtap="addItem">
        <view class="add-icon">+</view>
        <view class="item-name">新增称号</view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="item-grid">
      <view wx:for="{{badges}}" wx:key="id" class="item-card" bindtap="edit" data-id="{{item.id}}">
        <view class="emoji">{{item.icon}}</view>
        <view class="item-name">{{item.name}}</view>
      </view>
      <view class="item-card add-card" bindtap="addItem">
        <view class="add-icon">+</view>
        <view class="item-name">新增徽章</view>
      </view>
    </view>
  </block>
</view>
