.tabs { display: flex; background: #fff; border-radius: 16rpx; padding: 8rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #6b7280; border-radius: 12rpx; }
.tab.active { background: #409EFF; color: #fff; font-weight: 600; }
.item-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.item-card { background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); text-align: center; position: relative; }
.item-card image { width: 100%; height: 220rpx; border-radius: 12rpx; background: #f3f4f6; }
.item-name { margin-top: 12rpx; font-size: 26rpx; font-weight: 500; }
.item-tag { display: inline-block; margin-top: 8rpx; padding: 4rpx 12rpx; border-radius: 20rpx; font-size: 20rpx; }
.emoji { font-size: 80rpx; padding: 40rpx 0; }
.add-card { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300rpx; border: 4rpx dashed #d1d5db; background: transparent; box-shadow: none; }
.add-icon { font-size: 80rpx; color: #9ca3af; font-weight: 300; }
