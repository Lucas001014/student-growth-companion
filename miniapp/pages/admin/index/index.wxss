.welcome-card { 
  background: linear-gradient(135deg, rgba(0,245,212,0.15), rgba(123,44,247,0.1)); 
  border: 1px solid rgba(0,245,212,0.2);
  border-radius: 24rpx; 
  padding: 40rpx; 
  margin-bottom: 30rpx; 
}

.welcome-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.welcome-sub {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.stats-grid { 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 20rpx; 
  margin-top: 30rpx; 
  padding-top: 30rpx; 
  border-top: 1px solid rgba(255,255,255,0.06); 
}

.stat-item { 
  text-align: center; 
  background: rgba(0,245,212,0.08); 
  padding: 20rpx; 
  border-radius: 12rpx; 
  border: 1px solid rgba(0,245,212,0.1);
}

.stat-num { 
  font-size: 40rpx; 
  font-weight: 700; 
  color: #00f5d4;
}

.stat-label { 
  font-size: 22rpx; 
  color: #4a5568; 
  margin-top: 4rpx; 
}

.quick-grid { 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 20rpx; 
  margin-bottom: 30rpx; 
}

.quick-item { 
  background: rgba(15,23,42,0.8); 
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16rpx; 
  padding: 40rpx 20rpx; 
  text-align: center; 
  font-size: 28rpx; 
  color: #94a3b8;
}

.quick-icon { 
  font-size: 60rpx; 
  margin-bottom: 12rpx; 
}

.overview-row { 
  display: flex; 
  justify-content: space-between; 
  padding: 20rpx 0; 
  border-bottom: 1px solid rgba(255,255,255,0.04); 
  font-size: 28rpx; 
}

.overview-row:last-child { 
  border-bottom: none; 
}

.overview-label {
  color: #64748b;
}

.overview-value {
  color: #e2e8f0;
  font-weight: 500;
}
